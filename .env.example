# Required: Your OpenAI API key for LLM calls
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Model selection (defaults shown)
CLASSIFIER_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o

# Optional: Path to the JSON Lines log file
ROUTE_LOG_PATH=route_log.jsonl

# Optional: Confidence threshold (0.0-1.0). If confidence < threshold, treat as 'unclear'
# Set to 0 to disable. Example: 0.7
CONFIDENCE_THRESHOLD=0
